---
// The Five Pillars section. Used on the home page.
---

<section class="container" id="pillars">
  <div class="section-title reveal">
    <div class="section-title__label">IV003 — The Five Pillars</div>
    <h2 class="section-title__title">What we hold in <em>balance</em>.</h2>
  </div>

  <div class="pillars reveal">
    <div class="pillars__grid">

      <article class="pillar">
        <div class="pillar__visual">
          <svg viewBox="0 0 200 220" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
            <rect width="200" height="220" fill="#3D2EB8"/>
            <g fill="#82FFC0">
              <rect x="20" y="20" width="40" height="40"/><rect x="60" y="60" width="40" height="40"/>
              <rect x="100" y="20" width="40" height="40"/><rect x="140" y="60" width="40" height="40"/>
              <rect x="20" y="100" width="40" height="40"/><rect x="100" y="100" width="40" height="40"/>
              <rect x="60" y="140" width="40" height="40"/><rect x="140" y="140" width="40" height="40"/>
            </g>
          </svg>
        </div>
        <div class="pillar__meta">
          <div class="pillar__num">P / 01</div>
          <div class="pillar__name">Spatial</div>
          <div class="pillar__desc">Architecture, environment and flow — the physical conditions for experience.</div>
        </div>
      </article>

      <article class="pillar">
        <div class="pillar__visual">
          <svg viewBox="0 0 200 220" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
            <rect width="200" height="220" fill="#000"/>
            <g fill="#82FFC0">
              <rect x="20" y="20" width="20" height="20"/><rect x="60" y="40" width="20" height="20"/>
              <rect x="100" y="20" width="20" height="20"/><rect x="140" y="60" width="20" height="20"/>
              <rect x="40" y="80" width="20" height="20"/><rect x="80" y="100" width="20" height="20"/>
              <rect x="120" y="80" width="20" height="20"/><rect x="160" y="120" width="20" height="20"/>
              <rect x="20" y="140" width="20" height="20"/><rect x="60" y="160" width="20" height="20"/>
              <rect x="100" y="140" width="20" height="20"/><rect x="140" y="180" width="20" height="20"/>
            </g>
            <g fill="#3D2EB8">
              <rect x="40" y="40" width="20" height="20"/><rect x="100" y="80" width="20" height="20"/>
              <rect x="140" y="140" width="20" height="20"/><rect x="80" y="180" width="20" height="20"/>
            </g>
          </svg>
        </div>
        <div class="pillar__meta">
          <div class="pillar__num">P / 02</div>
          <div class="pillar__name">Technology</div>
          <div class="pillar__desc">Systems and infrastructure that quietly enable the space to perform.</div>
        </div>
      </article>

      <article class="pillar">
        <div class="pillar__visual">
          <svg viewBox="0 0 200 220" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
            <rect width="200" height="220" fill="#C05000"/>
            <g fill="#F2EDD8">
              <rect x="20" y="20" width="160" height="20"/>
              <rect x="20" y="60" width="100" height="20"/>
              <rect x="20" y="100" width="140" height="40"/>
              <rect x="20" y="160" width="60" height="40"/>
              <rect x="100" y="160" width="80" height="20"/>
            </g>
          </svg>
        </div>
        <div class="pillar__meta">
          <div class="pillar__num">P / 03</div>
          <div class="pillar__name">Brand &amp; Digital</div>
          <div class="pillar__desc">Identity, narrative and digital product — the connective layer across every touchpoint.</div>
        </div>
      </article>

      <article class="pillar">
        <div class="pillar__visual">
          <svg viewBox="0 0 200 220" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
            <rect width="200" height="220" fill="#C8B4DC"/>
            <g fill="#000" opacity="0.92">
              <rect x="30" y="30" width="60" height="6"/>
              <rect x="30" y="44" width="80" height="6"/>
              <rect x="30" y="58" width="50" height="6"/>
              <rect x="30" y="80" width="140" height="60" opacity="0.12"/>
              <rect x="30" y="150" width="100" height="6"/>
              <rect x="30" y="164" width="120" height="6"/>
              <rect x="30" y="178" width="70" height="6"/>
            </g>
          </svg>
        </div>
        <div class="pillar__meta">
          <div class="pillar__num">P / 04</div>
          <div class="pillar__name">Content</div>
          <div class="pillar__desc">Programming, story and curation — what the place actually says to the people inside it.</div>
        </div>
      </article>

      <article class="pillar">
        <div class="pillar__visual">
          <svg viewBox="0 0 200 220" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
            <rect width="200" height="220" fill="#F9F9F3"/>
            <g stroke="#000" stroke-width="1.5" fill="none">
              <line x1="20" y1="40" x2="180" y2="40"/>
              <line x1="20" y1="80" x2="180" y2="80"/>
              <line x1="20" y1="120" x2="180" y2="120"/>
              <line x1="20" y1="160" x2="180" y2="160"/>
            </g>
            <g fill="#3D2EB8">
              <rect x="50" y="34" width="12" height="12"/><rect x="120" y="74" width="12" height="12"/>
              <rect x="80" y="114" width="12" height="12"/><rect x="150" y="154" width="12" height="12"/>
            </g>
            <g fill="#C05000">
              <rect x="160" y="34" width="12" height="12"/><rect x="40" y="154" width="12" height="12"/>
            </g>
          </svg>
        </div>
        <div class="pillar__meta">
          <div class="pillar__num">P / 05</div>
          <div class="pillar__name">Time</div>
          <div class="pillar__desc">The dimension everyone forgets — how an experience evolves across hours, seasons, years.</div>
        </div>
      </article>

    </div>
  </div>
</section>
