---
interface TeamMemberData {
  name: string;
  role: string;
  photo?: string;
  photo_alt?: string;
  bio: string;
  links: { label: string; url: string }[];
}

interface Props {
  member: TeamMemberData;
}

const { member } = Astro.props;

const initials = member.name
  .split(/\s+/)
  .map((s) => s[0])
  .filter(Boolean)
  .slice(0, 2)
  .join('')
  .toUpperCase();

/**
 * Tiny inline markdown renderer for short bios.
 * Supports paragraph splits on blank lines, **bold**, *italic*, and single newlines as <br>.
 * For richer formatting, move bio content into a dedicated markdown file/field.
 */
function renderInlineMarkdown(src: string): string {
  const escape = (s: string) =>
    s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

  return src
    .split(/\n{2,}/)
    .map(
      (p) =>
        `<p>${escape(p.trim())
          .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
          .replace(/\*([^*]+)\*/g, '<em>$1</em>')
          .replace(/\n/g, '<br/>')}</p>`,
    )
    .join('');
}

const bioHtml = renderInlineMarkdown(member.bio ?? '');
---

<article class="team-member">
  <div
    class={`team-member__photo${member.photo ? '' : ' team-member__photo--placeholder'}`}
    aria-hidden={member.photo ? undefined : 'true'}
  >
    {member.photo ? (
      <img
        src={member.photo}
        alt={member.photo_alt ?? `${member.name}, ${member.role}`}
        loading="lazy"
      />
    ) : (
      <span class="team-member__initials">{initials}</span>
    )}
  </div>
  <div>
    <h3 class="team-member__name">{member.name}</h3>
    <div class="team-member__role">{member.role}</div>
    <div class="team-member__bio" set:html={bioHtml} />
    {member.links.length > 0 && (
      <div class="team-member__links">
        {member.links.map((l) => (
          <a href={l.url} target="_blank" rel="noopener noreferrer">{l.label}</a>
        ))}
      </div>
    )}
  </div>
</article>

<style>
  .team-member__initials {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    font-size: 42px;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: rgba(0, 0, 0, 0.55);
  }
</style>
