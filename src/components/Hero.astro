---
// Hero used on the home page. Dark background.
---

<header class="hero" id="top" data-theme="dark">
  <div class="container" style="display:flex; flex-direction:column; flex:1;">
    <div class="hero__head">
      <span class="accent">IV001 — Total Experience Design™</span>
      <span>Strategic Advisory · Design Lab · Est. 2026</span>
    </div>

    <div class="hero__main">
      <div class="hero__copy">
        <h1 class="hero__title">
          Spaces &amp; places,<br />
          designed <em>end&#8209;to&#8209;end</em>.
        </h1>
        <p class="hero__sub">
          A new framework for transformational fan, audience, visitor and customer
          experiences — engineered for ambition, built for delivery, measured by return.
        </p>
      </div>

      <figure class="hero__image">
        <img
          src="/assets/images/sculpture-portal.png"
          alt="A figure standing inside a luminous white sculptural portal, suggesting a transformational interior space."
          loading="eager"
          fetchpriority="high"
        />
        <figcaption class="hero__image-caption">FIG.&nbsp;01 / A space designed to be entered slowly</figcaption>
      </figure>
    </div>

    <div class="hero__foot">
      <span>London · New York · Singapore</span>
      <span class="hero__scroll-cue">Scroll to begin</span>
      <span>© {new Date().getFullYear()} Interval Studio</span>
    </div>
  </div>
</header>
